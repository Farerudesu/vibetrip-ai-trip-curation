# ============================================
# VibeTrip Environment Configuration
# ============================================
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
#
# NEVER commit your .env file — it's gitignored.
# ============================================

# --- Gemini AI ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# --- Google Maps Platform ---
# Enable Maps JavaScript API, Places API (New), Routes API, 
# Air Quality API, Pollen API, and Weather API in your GCP console.
# Get your key at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_PLATFORM_KEY="your_google_maps_key_here"

# --- Firebase Configuration ---
# Create a Firebase project at: https://console.firebase.google.com
# Enable Authentication (Google provider) and Cloud Firestore.
# Copy config from: Project Settings → General → Your apps → SDK setup
VITE_FIREBASE_API_KEY="your_firebase_api_key_here"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_DATABASE_URL="https://your-project-default-rtdb.firebasedatabase.app"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# --- Google OAuth (for native Android sign-in) ---
# Found in Firebase Console → Authentication → Sign-in method → Google → Web client ID
VITE_GOOGLE_OAUTH_CLIENT_ID="your_oauth_client_id.apps.googleusercontent.com"

# --- Server Configuration ---
# PORT: The port the dev server runs on
SERVER_PORT=3000

# VITE_SERVER_HOST: Your local network IP for native Android builds
# Find it with: ipconfig (Windows) or ifconfig (Mac/Linux)
# The Android app needs this to reach your dev server on the same network
VITE_SERVER_HOST="192.168.1.100"
